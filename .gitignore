# ═══════════════════════════════════════════════════════════════
# AURA Social – .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Flutter / Dart ──
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/pubspec.lock
*.dart.js
*.js_
*.js.deps
*.js.map

# ── Android ──
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.jks
*.keystore

# ── iOS ──
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Pods/
**/ios/.symlinks/
**/ios/DerivedData/
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/Podfile.lock

# ── macOS / Linux / Windows (Flutter desktop) ──
**/macos/Flutter/ephemeral/
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/linux/flutter/ephemeral/
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/windows/flutter/ephemeral/
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake

# ── Web ──
**/web/favicon.png
**/web/icons/

# ── IDE ──
# Android Studio / IntelliJ
**/.idea/
**/*.iml
**/*.ipr
**/*.iws
.idea/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/launch.json

# ── Python / FastAPI Backend ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
*.egg
.venv/
venv/
env/
.env
.env.local
.env.*.local

# ── Firebase ──
**/firebase/functions/node_modules/
**/firebase/.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── OS Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Secrets / Keys (QUAN TRỌNG) ──
*.pem
*.p12
*.key
*.cert
*-service-account.json
*service_account*.json
# google-services.json         ← KHÔNG ignore (team cần share)
# GoogleService-Info.plist      ← KHÔNG ignore (team cần share)
.env
.env.*
!.env.example
secrets/
credentials/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ──
*.swp
*.swo
*~
.cache/
coverage/
